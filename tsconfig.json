{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"verbatimModuleSyntax": true,
		"erasableSyntaxOnly": true,
		"declaration": true,
		"declarationMap": false,
		"sourceMap": false,
		"skipLibCheck": true,
		"types": ["@types/bun"]
	},
	"include": ["src", "test"]
}
