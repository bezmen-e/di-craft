{
	"name": "di-craft",
	"version": "0.0.21",
	"description": "A tiny, type-safe dependency injection container for TypeScript with an optional Next.js App Router adapter",
	"license": "MIT",
	"author": {
		"name": "Egor Bezmen",
		"email": "egor1911@gmail.com"
	},
	"type": "module",
	"packageManager": "bun@1.3.14",
	"sideEffects": false,
	"engines": {
		"node": ">=20"
	},
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./next/client": {
			"types": "./dist/next/client.d.mts",
			"default": "./dist/next/client.mjs"
		},
		"./next/server": {
			"types": "./dist/next/server.d.mts",
			"default": "./dist/next/server.mjs"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsdown",
		"test": "bun test",
		"typecheck": "tsc --noEmit -p tsconfig.src.json && tsc --noEmit -p tsconfig.test.json",
		"lint": "biome check .",
		"format": "biome check --write .",
		"publint": "publint",
		"pre-commit-hooks": "simple-git-hooks",
		"checks": "bun run lint && bun run typecheck && bun run test && bun run build && bun run publint"
	},
	"simple-git-hooks": {
		"pre-commit": "bun run lint && bun run typecheck"
	},
	"keywords": [
		"di",
		"di container",
		"dependency-injection",
		"dependency injection",
		"ioc",
		"inversion of control",
		"ioc container",
		"typescript",
		"container",
		"zero dependencies",
		"lightweight",
		"tiny",
		"tree-shakable",
		"nextjs",
		"next.js",
		"app router",
		"react server components",
		"rsc",
		"server components",
		"request scope",
		"ssr",
		"state hydration",
		"next adapter"
	],
	"homepage": "https://github.com/bezmen-e/di-craft",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bezmen-e/di-craft.git"
	},
	"bugs": {
		"url": "https://github.com/bezmen-e/di-craft/issues"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@types/bun": "1.3.14",
		"publint": "0.3.21",
		"simple-git-hooks": "2.13.1",
		"tsdown": "0.22.3",
		"typescript": "6.0.3"
	}
}
